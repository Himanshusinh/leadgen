# ---- Database (Phase 1) ----
# Local Postgres example. Create DB first:  createdb leadgen
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadgen?schema=public"

# ---- Auth ----
# Any long random string. Generate: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# ---- Phase 1: Lead source ----
# Google Places API key. https://developers.google.com/maps/documentation/places/web-service
# Leave blank to run in DEMO_MODE (returns sample leads so you can test the UI).
GOOGLE_PLACES_API_KEY=""

# ---- Phase 2: Enrichment ----
# Hunter.io — finds business emails from a domain. https://hunter.io/api
HUNTER_API_KEY=""
# (Email verification / NeverBounce intentionally skipped for now.)

# If true, app uses built-in sample data when an API key is missing.
DEMO_MODE="true"

# ---- Phase 3: Outreach (SMTP Settings) ----
# SMTP server settings to send live emails. If left blank, email sending will run in simulation mode.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="LeadGen Outreach"
SMTP_FROM_EMAIL=""

